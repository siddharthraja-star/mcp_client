<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>InsightStudios MCP Gateway</title>
  <!-- highlight.js — theme switches with the UI theme -->
  <link id="hljs-css" rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <style>
    :root {
      --bg:              #0f1117;
      --surface:         #161b27;
      --surface-alt:     #1c2133;
      --surface-hover:   #1e2540;
      --text:            #cdd5e0;
      --text-muted:      #8b9ab0;
      --text-faint:      #5c6b80;
      --border:          #2a3347;
      --border-input:    #3a4460;
      --header-bg:       #0b0d16;
      --header-link:     #6b7fa0;
      --th-bg:           #0b0d16;
      --th-color:        #cdd5e0;
      --input-bg:        #1a2035;
      --input-color:     #cdd5e0;
      --btn-bg:          #3d4f7c;
      --btn-color:       #e8edf5;
      --btn-hover:       #4a5e90;
      --badge-ok-bg:     #064e3b;
      --badge-ok-fg:     #6ee7b7;
      --badge-err-bg:    #7f1d1d;
      --badge-err-fg:    #fca5a5;
      --err-box-bg:      #3b1219;
      --err-box-fg:      #fca5a5;
      --shadow:          rgba(0,0,0,.4);
      --code-bg:         #0f1520;
      --code-color:      #8b9ab0;
      --hint-bg:         #12182a;
      --hint-color:      #8b9ab0;
      --link-color:      #7b9ce0;
      --builder-bg:      #0e1118;
      --builder-border:  #252b38;
      --builder-label:   #171c26;
      --builder-lbl-fg:  #7b8ba0;
      --builder-input:   #1a2035;
      --builder-input-fg:#cdd5e0;
      --builder-chip-bd: #2e3a50;
      --builder-req-bd:  #4a5a9e;
      --builder-req-fg:  #8899dd;
      --log-row-even:    #161b27;
      --log-row-odd:     #1c2133;
      --log-row-err:     #2a1010;
      --log-row-warn:    #221a09;
      --log-text:        #cdd5e0;
      --log-ts-color:    #8b9ab0;
      --log-footer-bg:   #0f1520;
      --log-footer-bd:   #2a3347;
      --log-footer-fg:   #5c6b80;
      --log-border:      #2a3347;
    }

    [data-theme="dark"] {
      --bg:              #f4f6f8;
      --surface:         #ffffff;
      --surface-alt:     #f8fafc;
      --surface-hover:   #f0f4f8;
      --text:            #1a1d27;
      --text-muted:      #555e70;
      --text-faint:      #8896a8;
      --border:          #e4e8ef;
      --border-input:    #d1d5db;
      --header-bg:       #1a1a2e;
      --header-link:     #a9b4c2;
      --th-bg:           #1a1a2e;
      --th-color:        #ffffff;
      --input-bg:        #ffffff;
      --input-color:     #1a1d27;
      --btn-bg:          #1a1a2e;
      --btn-color:       #ffffff;
      --btn-hover:       #2d2d4e;
      --badge-ok-bg:     #d1fae5;
      --badge-ok-fg:     #065f46;
      --badge-err-bg:    #fee2e2;
      --badge-err-fg:    #991b1b;
      --err-box-bg:      #fee2e2;
      --err-box-fg:      #991b1b;
      --shadow:          rgba(0,0,0,.08);
      --code-bg:         #f0f4f8;
      --code-color:      #1a1d27;
      --hint-bg:         #f4f6f8;
      --hint-color:      #555e70;
      --link-color:      #1a1a2e;
      --builder-bg:      #181b1f;
      --builder-border:  #34373d;
      --builder-label:   #22252b;
      --builder-lbl-fg:  #9ea5ad;
      --builder-input:   #2c3235;
      --builder-input-fg:#e0e2e4;
      --builder-chip-bd: #44444b;
      --builder-req-bd:  #5c6bc0;
      --builder-req-fg:  #9ea5ff;
      --log-row-even:    #ffffff;
      --log-row-odd:     #f8fafc;
      --log-row-err:     #fff5f5;
      --log-row-warn:    #fffcf0;
      --log-text:        #111827;
      --log-ts-color:    #374151;
      --log-footer-bg:   #f1f5f9;
      --log-footer-bd:   #e2e8f0;
      --log-footer-fg:   #64748b;
      --log-border:      #cbd5e1;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      transition: background .2s, color .2s;
    }

    header {
      background: var(--header-bg);
      color: #fff;
      padding: 16px 32px;
      display: flex;
      align-items: center;
      gap: 24px;
    }
    header a { color: var(--header-link); text-decoration: none; font-size: 14px; transition: color .15s; }
    header a:hover { color: #fff; }
    header .brand { font-weight: 700; font-size: 18px; color: #fff; margin-right: auto; }

    main { max-width: 1600px; margin: 32px auto; padding: 0 40px; }
    h1 { font-size: 22px; margin-bottom: 20px; }
    h2 { font-size: 16px; }

    a { color: var(--link-color); }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--surface);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 4px var(--shadow);
    }
    th {
      background: var(--th-bg);
      color: var(--th-color);
      padding: 12px 16px;
      text-align: left;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: .5px;
    }
    td {
      padding: 11px 16px;
      font-size: 14px;
      border-bottom: 1px solid var(--border);
      word-break: break-all;
      color: var(--text);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--surface-alt); }

    code {
      background: var(--code-bg);
      color: var(--code-color);
      padding: 1px 5px;
      border-radius: 3px;
      font-size: 13px;
    }

    select, input, textarea {
      background: var(--input-bg);
      color: var(--input-color);
      border-color: var(--border-input);
      transition: background .2s, color .2s, border-color .2s;
    }

    .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .badge-ok  { background: var(--badge-ok-bg);  color: var(--badge-ok-fg); }
    .badge-err { background: var(--badge-err-bg); color: var(--badge-err-fg); }
    .error-box { background: var(--err-box-bg); color: var(--err-box-fg); padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 14px; }
    .empty { color: var(--text-faint); font-size: 14px; padding: 24px 0; }

    /* ── markdown document viewer ─────────────────────────────────────── */
    .md-viewer {
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 12px var(--shadow);
    }
    .md-viewer-bar {
      background: var(--th-bg);
      color: var(--th-color);
      padding: 8px 16px;
      font-size: 12px;
      font-family: 'JetBrains Mono','Fira Code',monospace;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--border);
      letter-spacing: .2px;
    }
    .md-viewer-bar .md-icon { opacity: .7; }
    .md-scroll {
      max-height: 80vh;
      overflow-y: auto;
      background: var(--surface);
    }
    .md-body {
      max-width: 860px;
      margin: 0 auto;
      padding: 36px 48px;
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      font-size: 15px;
      line-height: 1.75;
    }
    .md-body h1 {
      font-size: 26px; font-weight: 700; margin: 0 0 16px;
      padding-bottom: 10px; border-bottom: 2px solid var(--border); color: var(--text);
    }
    .md-body h2 {
      font-size: 20px; font-weight: 700; margin: 32px 0 12px;
      padding-bottom: 6px; border-bottom: 1px solid var(--border); color: var(--text);
    }
    .md-body h3 { font-size: 16px; font-weight: 700; margin: 24px 0 8px; color: var(--text); }
    .md-body h4, .md-body h5, .md-body h6 { font-size: 14px; font-weight: 600; margin: 18px 0 6px; color: var(--text-muted); }
    .md-body p { margin: 0 0 14px; }
    .md-body ul { margin: 0 0 14px 24px; list-style: disc; }
    .md-body ol { margin: 0 0 14px 24px; list-style: decimal; }
    .md-body li { margin-bottom: 5px; }
    .md-body li > ul, .md-body li > ol { margin-top: 4px; margin-bottom: 4px; }
    .md-body strong { font-weight: 700; color: var(--text); }
    .md-body em { font-style: italic; }
    .md-body hr { border: none; border-top: 1px solid var(--border); margin: 28px 0; }
    .md-body blockquote {
      border-left: 4px solid var(--border-input); margin: 0 0 14px;
      padding: 8px 16px; color: var(--text-muted);
      background: var(--surface-alt); border-radius: 0 6px 6px 0;
    }
    .md-body code {
      background: var(--code-bg); color: var(--code-color);
      padding: 2px 6px; border-radius: 4px;
      font-size: 13px; font-family: 'JetBrains Mono','Fira Code','Cascadia Code',monospace;
    }
    .md-body pre {
      border-radius: 8px; overflow-x: auto; margin: 0 0 18px;
      font-size: 13px; line-height: 1.6;
    }
    .md-body pre code { background: none; padding: 0; border-radius: 0; font-size: inherit; }
    .md-body table { width: 100%; border-collapse: collapse; margin: 0 0 18px; font-size: 13.5px; }
    .md-body thead tr { background: var(--th-bg); }
    .md-body th {
      color: var(--th-color); padding: 9px 14px;
      text-align: left; font-weight: 600; font-size: 12px;
      text-transform: uppercase; letter-spacing: .5px;
    }
    .md-body td {
      padding: 9px 14px; border-bottom: 1px solid var(--border);
      color: var(--text); vertical-align: top; word-break: break-word;
    }
    .md-body tr:nth-child(even) td { background: var(--surface-alt); }
    .md-body tr:hover td { background: var(--surface-hover); }
    .md-body tr:last-child td { border-bottom: none; }
    .md-body a { color: var(--link-color); text-decoration: underline; }
    .md-body img { max-width: 100%; border-radius: 6px; border: 1px solid var(--border); }

    /* log viewer row classes */
    .lr { padding: 4px 14px 4px 12px; white-space: pre; color: var(--log-text); }
    .lr-even { background: var(--log-row-even); border-left: 3px solid transparent; }
    .lr-odd  { background: var(--log-row-odd);  border-left: 3px solid transparent; }
    .lr-err  { background: var(--log-row-err);  border-left: 3px solid #dc2626; }
    .lr-warn { background: var(--log-row-warn); border-left: 3px solid #d97706; }

    #themeToggle {
      background: rgba(255,255,255,.1);
      color: #d0d8e8;
      border: 1px solid rgba(255,255,255,.18);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 13px;
      cursor: pointer;
      white-space: nowrap;
      transition: background .2s;
      letter-spacing: .2px;
    }
    #themeToggle:hover { background: rgba(255,255,255,.18); }
  </style>
</head>
<body>
  <header>
    <span class="brand">InsightStudios MCP Gateway</span>
    <a href="/">Home</a>
    <a href="/servers">Servers</a>
    <a href="/tools">Tools</a>
    <a href="/run-tool">Run Tool</a>
    <button id="themeToggle" onclick="toggleTheme()">Dark mode</button>
  </header>
  <main>
    <%- body %>
  </main>
  <script>
    (function () {
      const saved = localStorage.getItem('mcp-theme') || 'light';
      applyTheme(saved);

      function applyTheme(t) {
        document.documentElement.setAttribute('data-theme', t);
        const btn = document.getElementById('themeToggle');
        if (btn) btn.textContent = t === 'dark' ? 'Light mode' : 'Dark mode';
        // 'light' attr = dark UI; 'dark' attr = light UI (themes are swapped)
        const hljsCss = document.getElementById('hljs-css');
        if (hljsCss) hljsCss.href = t === 'light'
          ? 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css'
          : 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css';
      }

      if (typeof hljs !== 'undefined') hljs.highlightAll();

      window.toggleTheme = function () {
        const cur = document.documentElement.getAttribute('data-theme') || 'light';
        const next = cur === 'dark' ? 'light' : 'dark';
        localStorage.setItem('mcp-theme', next);
        applyTheme(next);
      };
    })();
  </script>
</body>
</html>
