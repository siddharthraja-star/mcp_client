<%
const body = `
  <h1>MCP Servers</h1>
  ${error ? `<div class="error-box">${error}</div>` : ''}
  ${rows.length === 0 && !error ? '<p class="empty">No MCP servers found.</p>' : `
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Command</th>
        <th>Args</th>
        <th>Type</th>
        <th>Source</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      ${rows.map(r => `
        <tr>
          <td><strong>${r.name}</strong></td>
          <td><code>${r.command}</code></td>
          <td><code>${r.args || '-'}</code></td>
          <td>${r.type}</td>
          <td style="font-size:12px;color:#666">${r.source}</td>
          <td>
            <a href="/tools?server=${encodeURIComponent(r.name)}" style="font-size:13px">List Tools</a>
            &nbsp;|&nbsp;
            <a href="/run-tool?server=${encodeURIComponent(r.name)}" style="font-size:13px">Run Tool</a>
          </td>
        </tr>
      `).join('')}
    </tbody>
  </table>`}
`;
%>
<%- include('layout', { body }) %>
